# ============================================
#  AI Newsletter Empire - Environment Variables
# ============================================
# Copy this file to ".env" and fill in your keys.
# All of these are FREE to get. Instructions in README.md

# --- AI Brain (Groq - FREE, fast, reliable) ---
# Get it: https://console.groq.com → API Keys → Create
GROQ_API_KEY=your_groq_api_key_here

# --- Email: Resend (our OWN system, no Beehiiv) ---
# Get it: https://resend.com/api-keys (free: 100 emails/day = 3,000/mo)
RESEND_API_KEY=your_resend_api_key_here
# Free accounts use the shared sender. After verifying your domain:
# RESEND_FROM=The AI Hustle <newsletter@theaihustle.com>
RESEND_FROM=The AI Hustle <onboarding@resend.dev>

# --- Public URLs ---
LANDING_URL=https://theaihustle.surge.sh
# Set after deploying server.py to Render:
BACKEND_URL=https://your-backend.onrender.com

# --- Website Publish (optional) ---
WEBSITE_POSTS_DIR=./posts

# --- Niche / Branding ---
NEWSLETTER_NAME=The AI Hustle
NEWSLETTER_TAGLINE=AI tools & money moves, delivered fresh daily.
TARGET_AUDIENCE=Students & side-hustlers building income with AI

# --- Affiliate links (the money-makers) ---
AFFILIATE_LINKS={"ChatGPT Plus":"https://example.com/chatgpt","Notion AI":"https://example.com/notion"}
