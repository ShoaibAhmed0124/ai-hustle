# ============================================
#  AI Newsletter Empire - Environment Variables
# ============================================
# Copy this file to ".env" and fill in your keys.
# All of these are FREE to get. Instructions in README.md

# --- AI Brain (Google Gemini - FREE) ---
# Get it: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Email Provider (Beehiiv - FREE up to 2500 subs) ---
# Get it: https://developers.beehiiv.com/  (after creating a publication)
BEEHIIV_API_KEY=your_beehiiv_api_key_here
BEEHIIV_PUBLICATION_ID=your_publication_id_here

# --- Website Publish (optional - GitHub Pages needs no key) ---
# Leave blank to just save files locally instead of pushing
WEBSITE_POSTS_DIR=./posts

# --- Niche / Branding ---
NEWSLETTER_NAME=The AI Hustle
NEWSLETTER_TAGLINE=AI tools & money moves, delivered fresh daily.
TARGET_AUDIENCE=Students & side-hustlers building income with AI

# --- Affiliate links (the money-makers) ---
# Add your affiliate links here. Agents will weave them into content.
AFFILIATE_LINKS={"ChatGPT Plus":"https://example.com/chatgpt","Notion AI":"https://example.com/notion"}
